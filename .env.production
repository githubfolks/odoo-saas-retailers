# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql://postgres:CHANGE_THIS_PASSWORD@YOUR_DB_HOST:5432/app_db

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_TO_RANDOM_64_CHAR_HEX
ADMIN_TOKEN=CHANGE_THIS_TO_RANDOM_64_CHAR_HEX

# ─── App ──────────────────────────────────────────────────────────────────────
DEBUG=false
APP_BASE_URL=https://yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_PORT=16379

# ─── Ports ────────────────────────────────────────────────────────────────────
FASTAPI_PORT=9011

# ─── WhatsApp ─────────────────────────────────────────────────────────────────
WAOFFICIAL_BASE_URL=https://app.waofficial.com/api
WHATSAPP_VERIFY_TOKEN=CHANGE_THIS_TO_SOMETHING_SECRET

# ─── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY=rzp_live_XXXXXXXXXXXXXX
RAZORPAY_SECRET=CHANGE_THIS

# ─── OpenAI (inventory forecasting) ──────────────────────────────────────────
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXX
OPENAI_MODEL=gpt-4

# ─── Inventory tuning (defaults are fine to keep) ─────────────────────────────
FORECAST_LOOKBACK_DAYS=365
LOW_STOCK_ALERT_THRESHOLD=0.2
DEMAND_FORECAST_MIN_CONFIDENCE=0.7
INVENTORY_SYNC_INTERVAL_MINUTES=15
ALERT_CHECK_INTERVAL_MINUTES=60
NOTIFICATION_SEND_INTERVAL_MINUTES=5
